# OpenClaw 多Agent配置 - 环境变量模板
# 复制此文件为 .env 并填入你的真实值
# 永远不要提交 .env 文件到Git！

# ============================================
# Discord Bot Tokens (从 Discord Developer Portal 获取)
# ============================================

# Niko (总指挥)
NIKO_BOT_TOKEN=your_niko_bot_token_here

# 文匠 (文案专家)
WENJIANG_BOT_TOKEN=your_wenjiang_bot_token_here

# 极客 (技术专家)
GEEK_BOT_TOKEN=your_geek_bot_token_here

# 猎手 (调研专家)
HUNTER_BOT_TOKEN=your_hunter_bot_token_here

# 苏格拉底 (分析专家)
SOCRATES_BOT_TOKEN=your_socrates_bot_token_here

# 金手指 (数据专家)
GOLDEN_BOT_TOKEN=your_golden_bot_token_here

# 造物主 (架构专家)
CREATOR_BOT_TOKEN=your_creator_bot_token_here

# ============================================
# Discord IDs (开启开发者模式后右键复制)
# ============================================

# 你的 Discord User ID
YOUR_DISCORD_USER_ID=your_user_id_here

# 服务器 ID (Guild ID)
DISCORD_GUILD_ID=your_guild_id_here

# 频道 ID (Channel ID)
DISCORD_CHANNEL_ID=your_channel_id_here

# ============================================
# Bot Discord User IDs (不是Token，是User ID)
# ============================================

NIKO_BOT_USER_ID=niko_bot_user_id
WENJIANG_BOT_USER_ID=wenjiang_bot_user_id
GEEK_BOT_USER_ID=geek_bot_user_id
HUNTER_BOT_USER_ID=hunter_bot_user_id
SOCRATES_BOT_USER_ID=socrates_bot_user_id
GOLDEN_BOT_USER_ID=golden_bot_user_id
CREATOR_BOT_USER_ID=creator_bot_user_id

# ============================================
# OpenClaw Gateway
# ============================================

# Gateway Token (自动生成，通常不需要修改)
# GATEWAY_TOKEN=your_gateway_token_here

# ============================================
# 可选：API Keys
# ============================================

# Kimi API Key (如果使用)
# KIMI_API_KEY=your_kimi_api_key_here

# 其他API Keys...
